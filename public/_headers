# Netlify / Cloudflare Pages _headers file
#
# These are Netlify-style headers. Most other static hosts (Cloudflare
# Pages, Render, Vercel via vercel.json, etc.) also support this format
# or have their own equivalent.
#
# Long-cache static assets
/*
  X-Content-Type-Options: nosniff
  X-Frame-Options: DENY
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: camera=(), microphone=(), geolocation=()

# Immutable for hashed assets
/_next/*
  Cache-Control: public, max-age=31536000, immutable

/*.js
  Cache-Control: public, max-age=31536000, immutable

/*.css
  Cache-Control: public, max-age=31536000, immutable

/*.woff2
  Cache-Control: public, max-age=31536000, immutable

/*.webp
  Cache-Control: public, max-age=31536000, immutable

/*.jpg
  Cache-Control: public, max-age=31536000, immutable

/*.png
  Cache-Control: public, max-age=31536000, immutable

/*.svg
  Cache-Control: public, max-age=31536000, immutable

# Short-cache for HTML so updates ship fast
/*.html
  Cache-Control: public, max-age=0, must-revalidate
