# Required for password reset emails (dev: logged to console)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Database location (defaults to .data/printwearx.db)
DATABASE_PATH=.data/printwearx.db

# Optional: email service for password resets (Resend example)
# RESEND_API_KEY=re_xxx

# Optional: in production, set NODE_ENV=production
# NODE_ENV=production
